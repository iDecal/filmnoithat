---
const nav = [
  {
    label: "Dịch vụ",
    href: "/dich-vu/dan-film-noi-that",
    children: [
      { label: "Tổng quan dịch vụ", href: "/dich-vu/dan-film-noi-that" },
      { label: "Dán film bàn & kệ", href: "/dich-vu/ban-ke" },
      { label: "Dán film tủ bếp", href: "/dich-vu/tu-bep" },
      { label: "Dán film tường & trần", href: "/dich-vu/tuong-tran" },
      { label: "Dán film thang máy", href: "/dich-vu/thang-may" }
    ]
  },
  {
    label: "Vật liệu",
    href: "/vat-lieu",
    children: [
      { label: "Tất cả vật liệu", href: "/vat-lieu" },
      { label: "Film vân gỗ", href: "/vat-lieu/van-go" },
      { label: "Film vân vải", href: "/vat-lieu/van-vai" },
      { label: "Film kim loại", href: "/vat-lieu/kim-loai" },
      { label: "Film giả đá", href: "/vat-lieu/gia-da" }
    ]
  },
  {
    label: "Công trình",
    href: "/cong-trinh",
    children: [
      { label: "Tất cả công trình", href: "/cong-trinh" },
      { label: "Văn phòng", href: "/cong-trinh/van-phong" },
      { label: "Nhà phố", href: "/cong-trinh/nha-pho" },
      { label: "Showroom", href: "/cong-trinh/showroom" }
    ]
  },
  {
    label: "Blog",
    href: "/blog",
    children: [
      { label: "Tất cả bài viết", href: "/blog" },
      { label: "Cách chọn film nội thất", href: "/blog/cach-chon-film-noi-that" },
      { label: "Báo giá thi công", href: "/blog/bao-gia-dan-film" },
      { label: "So sánh vật liệu", href: "/blog/so-sanh-film-noi-that" }
    ]
  },
  { label: "Dự án", href: "/du-an" },
  { label: "Giới thiệu", href: "/gioi-thieu" },
  { label: "Liên hệ", href: "/lien-he" }
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b border-base-200">

  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- 🌿 LOGO -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-primary-500"></div>
      <div class="font-medium tracking-wide">
        Film Nội Thất
      </div>
    </a>

    <!-- 🧭 DESKTOP MENU -->
    <nav class="hidden md:flex items-center gap-6 text-sm text-base-700">

      {nav.map(item => (
        <div class="relative group">

          <a href={item.href} class="flex items-center gap-1 hover:text-primary-500 transition">
            {item.label}
            {item.children && <span class="text-xs">▾</span>}
          </a>

          {item.children && (
            <div class="absolute left-0 top-full mt-3 hidden group-hover:block bg-white border border-base-200 rounded-xl shadow-lg min-w-[220px] overflow-hidden">

              {item.children.map(child => (
                <a href={child.href}
                   class="block px-4 py-2 text-sm hover:bg-base-100">
                  {child.label}
                </a>
              ))}

            </div>
          )}

        </div>
      ))}

    </nav>

    <!-- CTA -->
    <a href="/lien-he"
      class="hidden md:block bg-primary-500 text-white text-sm px-5 py-2 rounded-full hover:opacity-90">
      Nhận báo giá
    </a>

    <!-- MOBILE BTN -->
    <button id="menuBtn" class="md:hidden flex flex-col gap-1">
      <span class="w-6 h-[2px] bg-base-900"></span>
      <span class="w-6 h-[2px] bg-base-900"></span>
      <span class="w-6 h-[2px] bg-base-900"></span>
    </button>

  </div>

  <!-- 📱 MOBILE MENU -->
  <div id="mobileMenu" class="hidden md:hidden border-t border-base-200 bg-white">

    <div class="px-6 py-4 space-y-4 text-sm">

      {nav.map(item => (
        <div class="border-b border-base-100 pb-3">

          <a href={item.href} class="block font-medium py-2">
            {item.label}
          </a>

          {item.children && (
            <div class="pl-4 space-y-2 text-base-600">
              {item.children.map(child => (
                <a href={child.href} class="block py-1">
                  {child.label}
                </a>
              ))}
            </div>
          )}

        </div>
      ))}

      <a href="/lien-he"
        class="block text-center bg-primary-500 text-white py-3 rounded-xl mt-4">
        Nhận báo giá
      </a>

    </div>

  </div>

</header>

<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");

  btn?.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>
