---
const nav = [
  {
    label: "Dịch vụ",
    href: "/dich-vu/dan-film-noi-that",
    children: [
      { label: "Tổng quan dịch vụ", href: "/dich-vu/dan-film-noi-that" },
      { label: "Dán film bàn & kệ", href: "/dich-vu/ban-ke" },
      { label: "Dán film tủ bếp", href: "/dich-vu/tu-bep" },
      { label: "Dán film tường & trần", href: "/dich-vu/tuong-tran" },
      { label: "Dán film thang máy", href: "/dich-vu/dan-film-thang-may" }
    ]
  },
  {
    label: "Vật liệu",
    href: "/vat-lieu",
    children: [
      { label: "Tất cả vật liệu", href: "/vat-lieu" },
      { label: "Film vân gỗ", href: "/vat-lieu/van-go" },
      { label: "Film vân vải", href: "/vat-lieu/van-vai" },
      { label: "Film kim loại", href: "/vat-lieu/kim-loai" },
      { label: "Film giả đá", href: "/vat-lieu/gia-da" }
    ]
  },
  {
    label: "Công trình",
    href: "/cong-trinh",
    children: [
      { label: "Tất cả công trình", href: "/cong-trinh" },
      { label: "Văn phòng", href: "/cong-trinh/van-phong" },
      { label: "Nhà phố", href: "/cong-trinh/nha-pho" },
      { label: "Showroom", href: "/cong-trinh/showroom" }
    ]
  },
  {
    label: "Blog",
    href: "/blog",
    children: [
      { label: "Tất cả bài viết", href: "/blog" },
      { label: "Cách chọn film nội thất", href: "/blog/cach-chon-film-noi-that" },
      { label: "Báo giá thi công", href: "/blog/bao-gia-dan-film" },
      { label: "So sánh vật liệu", href: "/blog/so-sanh-film-noi-that" }
    ]
  },
  { label: "Giới thiệu", href: "/gioi-thieu" },
  { label: "Liên hệ", href: "/lien-he" }
];
---

<header class="w-full bg-white border-b sticky top-0 z-50">

  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- LOGO -->
    <a href="/" class="flex items-center gap-2">
      <!-- có thể thay bằng img -->
      <span class="text-xl font-light tracking-wide">
        Film Nội Thất
      </span>
    </a>

    <!-- DESKTOP MENU -->
    <nav class="hidden md:flex items-center gap-8">

      {nav.map((item) => (
        <div class="relative group">

          <a
            href={item.href}
            class="flex items-center gap-1 py-2 hover:text-orange-600 transition"
          >
            {item.label}
            {item.children && <span class="text-xs">▾</span>}
          </a>

          {item.children && (
            <div
              class="absolute left-0 top-full w-56 opacity-0 invisible
                     group-hover:opacity-100 group-hover:visible
                     transition-all duration-200 z-50"
            >
              <div class="h-3"></div>

              <div class="bg-white border rounded-xl shadow-lg overflow-hidden">

                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm hover:bg-gray-100"
                  >
                    {child.label}
                  </a>
                ))}

              </div>
            </div>
          )}

        </div>
      ))}

      <!-- 🔥 NÚT NHẬN BÁO GIÁ DESKTOP -->
      <a
        href="/lien-he"
        class="ml-4 bg-orange-600 text-white px-5 py-2 rounded-full hover:bg-orange-700 transition"
      >
        Nhận báo giá
      </a>

    </nav>

    <!-- MOBILE BUTTON -->
    <button
      id="menuBtn"
      class="md:hidden text-3xl transition"
      aria-label="Toggle menu"
    >
      ☰
    </button>

  </div>

  <!-- MOBILE MENU -->
  <div id="mobileMenu" class="hidden md:hidden border-t bg-white">

    <div class="px-6 py-4 space-y-2">

      {nav.map((item) => (
        <details class="border-b pb-2">

          <summary class="py-3 flex justify-between items-center cursor-pointer text-xl font-medium">
            {item.label}
            {item.children && <span>+</span>}
          </summary>

          {item.children ? (
            <div class="pl-4 pb-2 space-y-2 text-sm text-gray-600">
              {item.children.map((child) => (
                <a href={child.href} class="block py-1">
                  {child.label}
                </a>
              ))}
            </div>
          ) : (
            <a href={item.href} class="block py-2 text-sm">
              Đi tới {item.label}
            </a>
          )}

        </details>
      ))}

      <!-- CTA MOBILE -->
      <a
        href="/lien-he"
        class="block text-center bg-orange-600 text-white py-3 rounded-xl mt-4"
      >
        Nhận báo giá
      </a>

    </div>

  </div>

</header>

<!-- SCRIPT: TOGGLE + ĐỔI ICON ☰ ↔ ✕ -->
<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");

  let open = false;

  btn?.addEventListener("click", () => {
    open = !open;
    menu?.classList.toggle("hidden");

    // đổi icon
    btn.textContent = open ? "✕" : "☰";
  });
</script>
