---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    question: "Film dán nội thất có bền không? Dùng được bao lâu?",
    answer: "Các dòng film chính hãng từ Toda, Infeel có độ bền từ 10-15 năm. Film có khả năng chống trầy xước, không bong tróc tự nhiên và chịu được khí hậu nóng ẩm tại Việt Nam."
  },
  {
    question: "Có dán được trên bề mặt tường hay bê tông không?",
    answer: "Film nội thất chuyên dụng cho các bề mặt nhẵn như gỗ, kim loại, nhựa, kính hoặc đá. Đối với bề mặt tường vôi, chúng tôi khuyên nên xử lý bả phẳng và sơn lót trước khi dán để đảm bảo độ bám dính."
  },
  {
    question: "Quy trình thi công mất bao lâu?",
    answer: "Tùy diện tích, nhưng thông thường các hạng mục như tủ bếp hoặc cửa thang máy chỉ mất từ 4-8 tiếng trong ngày. Bạn có thể sử dụng ngay sau khi thi công."
  },
  {
    question: "Chính sách bảo hành tại iDecal như thế nào?",
    answer: "iDecal bảo hành 2 năm cho lỗi kỹ thuật thi công (bong mép, bọt khí) và hỗ trợ bảo trì trọn đời cho khách hàng tại TP.HCM & Bình Dương."
  }
];
---

<BaseLayout 
  title="Liên Hệ iDecal - Tư Vấn & Khảo Sát Tận Nơi Miễn Phí"
  description="Liên hệ đội ngũ kỹ thuật iDecal để nhận báo giá dán film nội thất. Hỗ trợ khảo sát, mang mẫu tận nơi tại TP.HCM và Bình Dương trong 24h."
>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-20">
        <div>
          <h1 class="text-5xl font-light mb-8 italic">Kết nối với <span class="font-medium text-primary-500">iDecal</span></h1>
          <p class="text-base-500 mb-12 text-lg">
            Bạn có dự án cần cải tạo? Đừng ngần ngại gửi tin nhắn, đội ngũ kỹ thuật sẽ phản hồi và tư vấn giải pháp tối ưu nhất về chi phí cho bạn.
          </p>
          
          <div class="space-y-8">
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-primary-50 rounded-full flex items-center justify-center text-primary-500 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <h4 class="font-bold text-base-900">Hotline / Zalo</h4>
                <p class="text-base-500 text-xl font-medium">0866 077 040</p>
              </div>
            </div>

            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-primary-50 rounded-full flex items-center justify-center text-primary-500 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h4 class="font-bold text-base-900">Khu vực hoạt động</h4>
                <p class="text-base-500 leading-relaxed">TP. Hồ Chí Minh (Q7, Q12, Thủ Đức, Bình Thạnh...) & Tỉnh Bình Dương.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-base-900 rounded-[3rem] p-10 md:p-16 text-white text-center flex flex-col justify-center">
          <h2 class="text-3xl font-light italic mb-6 text-white/90">Yêu cầu khảo sát tận nơi</h2>
          <p class="text-white/50 mb-10 text-sm">Chúng tôi sẽ mang theo Catalog hơn 1000 mẫu để bạn chọn trực tiếp trên bề mặt nội thất của mình.</p>
          <a href="https://zalo.me/0866077040" class="bg-white text-black py-5 rounded-full font-bold text-lg hover:bg-primary-500 hover:text-white transition-all shadow-2xl">
            Chat qua Zalo ngay
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-50 border-t border-base-200">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-light italic mb-4">Giải đáp thắc mắc</h2>
        <p class="text-base-500 text-sm">Những câu hỏi iDecal thường nhận được từ phía khách hàng.</p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-white rounded-2xl border border-base-100 overflow-hidden">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none focus:outline-none">
              <span class="font-bold text-base-800 pr-4">{faq.question}</span>
              <span class="text-primary-500 transition-transform group-open:rotate-180">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6 pt-0 text-base-500 text-sm leading-relaxed border-t border-base-50">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Loại bỏ dấu mũi tên mặc định của details trên một số trình duyệt */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
