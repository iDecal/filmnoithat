---
import BaseLayout from "../layouts/BaseLayout.astro";

// 1. Dữ liệu Sản phẩm (Vật liệu) - Thêm ảnh cụ thể
const productCategories = [
  { 
    name: "Film Vân Gỗ", 
    items: "Sồi (Oak), Óc Chó (Walnut), Gỗ Khô", 
    image: "/images/vat-lieu/van-go/CAD402-goc.jpg",
    link: "/san-pham/van-go"
  },
  { 
    name: "Film Vân Đá", 
    items: "Marble, Granite, Ceramic cao cấp", 
    image: "/images/cat-van-da.webp",
    link: "/san-pham/van-da"
  },
  { 
    name: "Film Màu Đơn Sắc", 
    items: "Matte (Nhám mờ) & Glossy (Bóng)", 
    image: "/images/cat-mau-tron.webp",
    link: "/san-pham/mau-tron"
  },
  { 
    name: "Film Vân Vải & Da", 
    items: "Canvas, Linen, Da thuộc nhân tạo", 
    image: "/images/cat-van-vai.webp",
    link: "/san-pham/van-vai"
  }
];

// 2. Dữ liệu Dịch vụ
const services = [
  { title: "Dán film thang máy", desc: "Biến kim loại lạnh thành vật liệu nội thất sang trọng.", image: "/images/s-elevator.webp" },
  { title: "Dán film tủ bếp", desc: "Thay đổi màu sắc không gian bếp mà không cần thay mới.", image: "public/images/blog/dan-film-noi-that-tu-bep.webp" },
  { title: "Dán film kính văn phòng", desc: "Tăng tính riêng tư, giữ ánh sáng chuyên nghiệp.", image: "/images/s-glass.webp" },
  { title: "Dán showroom/cửa hàng", desc: "Cải tạo quầy kệ, vách trang trí nhanh chóng.", image: "/images/s-showroom.webp" }
];

const projects = [
  { title: "Thang máy khách sạn", tag: "Premium", style: "Vân gỗ sồi", image: "/images/p1.webp" },
  { title: "Văn phòng Tech", tag: "Infeel", style: "Kính mờ hiện đại", image: "/images/p2.webp" },
  { title: "Nhà phố cao cấp", tag: "Toda", style: "Gỗ Walnut trầm", image: "/images/p3.webp" }
];

const blogPosts = [
  { title: "5 Lý do chọn Film dán thay vì sơn bệt", date: "15/04/2026", image: "/images/blog/wd259-2-f13e5564-4976-42fd-9cec-adb506d15c94.webp" },
  { title: "Hướng dẫn tự dán film tại nhà đúng kỹ thuật", date: "10/04/2026", image: "/images/b2.webp" }
];
---

<BaseLayout title="Film Dán Nội Thất - Vật Liệu & Thi Công Cao Cấp">

<section class="min-h-[90vh] flex items-center justify-center px-6 relative overflow-hidden bg-base-50">
  <div class="relative max-w-5xl text-center z-10">
    <p class="text-xs tracking-[0.4em] text-base-500 uppercase mb-6 font-bold">Interior Film Studio</p>
    <h1 class="text-5xl md:text-7xl font-light leading-tight text-base-900">
      Lớp áo mới cho<br />
      <span class="font-medium text-primary-500 italic">nội thất bền vững</span>
    </h1>
    <p class="mt-8 text-base-600 max-w-2xl mx-auto text-lg leading-relaxed">
      Chuyên vật liệu film nội thất chính hãng và dịch vụ thi công trọn gói tại TP.HCM & Bình Dương. Cải tạo không gian chỉ trong 24h.
    </p>
    <div class="mt-12 flex flex-wrap gap-4 justify-center">
      <a href="#kho-vat-lieu" class="bg-primary-500 hover:bg-primary-600 text-white px-10 py-4 rounded-full transition shadow-xl font-bold">
        Khám phá vật liệu
      </a>
      <a href="https://zalo.me/your-number" class="border border-base-300 px-10 py-4 rounded-full hover:bg-white transition font-medium">
        Nhận báo giá thi công
      </a>
    </div>
  </div>
</section>

<section id="kho-vat-lieu" class="py-24 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-4xl font-light italic text-base-900 mb-4">Tổng kho vật liệu film nội thất</h2>
        <p class="text-base-500 text-lg">Hàng trăm mẫu film có sẵn, từ vân gỗ tự nhiên đến vân đá sang trọng. Sẵn sàng giao ngay hoặc thi công trực tiếp.</p>
      </div>
      <a href="/san-pham" class="text-primary-500 font-bold border-b-2 border-primary-500 pb-1 hover:text-primary-600 transition">
        Xem toàn bộ bộ sưu tập →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {productCategories.map(cat => (
        <a href={cat.link} class="group block">
          <div class="aspect-[3/4] rounded-3xl overflow-hidden mb-6 shadow-sm group-hover:shadow-2xl transition duration-500">
            <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
          </div>
          <h3 class="text-xl font-medium text-base-900 group-hover:text-primary-500 transition">{cat.name}</h3>
          <p class="text-sm text-base-500 mt-2">{cat.items}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="py-24 px-6 bg-base-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-light italic mb-4">Dịch vụ thi công chuyên nghiệp</h2>
      <p class="text-base-500 max-w-2xl mx-auto font-medium text-lg">Xử lý tỉ mỉ các chi tiết khó nhất, đảm bảo độ thẩm mỹ tuyệt đối cho công trình của bạn.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map(s => (
        <div class="bg-white p-2 rounded-[2rem] border border-base-200 hover:shadow-xl transition group">
          <div class="aspect-square rounded-[1.8rem] overflow-hidden mb-6">
            <img src={s.image} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
          </div>
          <div class="px-6 pb-6 text-center">
            <h3 class="font-bold text-base-900 text-lg mb-2">{s.title}</h3>
            <p class="text-sm text-base-500 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-24 px-6 bg-white">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-24 items-center">
    <div>
      <h2 class="text-4xl font-light mb-12 italic">Lợi ích vượt trội</h2>
      <div class="space-y-10">
        <div class="flex gap-6">
          <span class="text-3xl">💰</span>
          <div>
            <h4 class="font-bold text-xl text-base-900 mb-2">Tiết kiệm 70% chi phí</h4>
            <p class="text-base-600">Thay đổi diện mạo nội thất mà không cần mua mới. Tiết kiệm tối đa ngân sách đầu tư.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <span class="text-3xl">✨</span>
          <div>
            <h4 class="font-bold text-xl text-base-900 mb-2">Thi công sạch sẽ</h4>
            <p class="text-base-600">Không bụi gỗ, không mùi sơn, không tiếng ồn. Bạn có thể sử dụng không gian ngay lập tức.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <span class="text-3xl">🛡️</span>
          <div>
            <h4 class="font-bold text-xl text-base-900 mb-2">Độ bền trên 10 năm</h4>
            <p class="text-base-600">Khả năng kháng ẩm, chống trầy xước và chịu nhiệt cực tốt trong môi trường Việt Nam.</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="bg-base-900 p-12 rounded-[3rem] text-white relative overflow-hidden">
      <h2 class="text-3xl font-light mb-10 italic">Quy trình 5 bước</h2>
      <div class="space-y-8 relative z-10">
        {["Tư vấn & Xem mẫu tại nhà", "Khảo sát & Đo đạc thực tế", "Báo giá vật tư & Nhân công", "Thi công tỉ mỉ từng mép cạnh", "Bàn giao & Bảo hành 2-5 năm"].map((step, i) => (
          <div class="flex gap-6 items-center border-b border-white/10 pb-4">
            <span class="text-primary-500 font-serif italic text-2xl font-bold">0{i+1}.</span>
            <p class="font-medium text-lg">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="py-24 px-6 bg-base-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
        <h2 class="text-4xl font-light">Công trình thực tế</h2>
        <p class="text-base-500 mt-4">Các dự án cho Toyota, The Hive và hàng ngàn căn hộ tại TP.HCM & Bình Dương.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => (
        <div class="group bg-white rounded-3xl overflow-hidden border border-base-200 shadow-sm hover:shadow-2xl transition duration-500">
          <div class="h-72 overflow-hidden relative">
            <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
            <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase">{p.tag}</div>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-base-900 mb-2">{p.title}</h3>
            <p class="text-sm text-base-500 italic">{p.style}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-24 px-6 bg-white border-t border-base-200">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-16">
      <h2 class="text-3xl font-light italic">Kiến thức bề mặt</h2>
      <a href="/blog" class="text-sm font-bold text-primary-500 uppercase tracking-widest">Xem tất cả</a>
    </div>
    <div class="grid md:grid-cols-2 gap-12">
      {blogPosts.map(post => (
        <a href="#" class="group block">
          <div class="aspect-video rounded-3xl overflow-hidden mb-6">
            <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:rotate-1 group-hover:scale-105 transition duration-500" />
          </div>
          <div class="flex gap-4 items-center mb-4">
             <span class="text-[10px] font-bold bg-primary-500 text-white px-3 py-1 rounded-full uppercase tracking-widest">Cẩm nang</span>
             <span class="text-xs text-base-400 font-medium">{post.date}</span>
          </div>
          <h3 class="text-2xl font-medium leading-snug group-hover:text-primary-500 transition">{post.title}</h3>
          <p class="mt-4 text-primary-500 font-bold flex items-center gap-2"> ĐỌC THÊM <span>→</span></p>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="py-32 bg-base-900 text-white text-center px-6 relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 grayscale">
    <img src="/images/cta-pattern.webp" alt="Vật liệu film" class="w-full h-full object-cover" />
  </div>
  <div class="relative z-10">
    <h2 class="text-5xl font-light mb-8 italic">Bạn đã sẵn sàng đổi mới?</h2>
    <p class="text-white/60 mb-12 max-w-xl mx-auto text-lg leading-relaxed">
      Liên hệ để nhận tư vấn giải pháp vật liệu phù hợp cho công trình của bạn. Chúng tôi mang mẫu đến tận nơi khảo sát miễn phí.
    </p>
    <a href="https://zalo.me/your-number" class="bg-white text-black px-12 py-5 rounded-full hover:bg-primary-500 hover:text-white transition-all font-bold text-lg inline-block shadow-2xl">
      Chat Zalo Báo Giá
    </a>
  </div>
</section>

</BaseLayout>
