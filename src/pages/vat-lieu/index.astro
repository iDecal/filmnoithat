---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Danh sách vật liệu dựa trên ảnh bạn gửi
const materials = [
  { id: 'van-go', name: "Vân Gỗ Cao Cấp", desc: "Mô phỏng hoàn hảo thớ gỗ tự nhiên, mang lại vẻ sang trọng và ấm cúng.", image: "/images/vat-lieu/van-go/CAD402-goc.jpg" },
  { id: 'don-sac', name: "Vân Đơn Sắc", desc: "Các tông màu tối giản, hiện đại phù hợp cho không gian tối giản (Minimalism).", image: "/images/vat-lieu/don-sac/DEN001.jpg" },
  { id: 'bong-mo', name: "Vân Bóng Mờ", desc: "Bề mặt tinh tế, chống bám vân tay, tạo chiều sâu cho nội thất.", image: "/images/vat-lieu/bong-mo.webp" },
  { id: 'van-da', name: "Vân Đá Cẩm Thạch", desc: "Họa tiết Marble sang trọng dành cho bàn bếp, vách tivi và sảnh đón.", image: "/images/vat-lieu/van-da.webp" },
  { id: 'van-vai', name: "Vân Vải", desc: "Hiệu ứng bề mặt vải dệt độc đáo, mang lại cảm giác mềm mại cho tủ quần áo.", image: "/images/vat-lieu/van-vai/CAN034.jpg" },
  { id: 'be-tong', name: "Vân Bê Tông", desc: "Phong cách Industrial mạnh mẽ, thô mộc cho quán cafe, văn phòng.", image: "/images/vat-lieu/be-tong/CORANCE-CAG816-cuon.jpg" },
  { id: 'kim-loai', name: "Vân Kim Loại", desc: "Hiệu ứng thép không gỉ, nhôm xước cho cửa thang máy và thiết bị.", image: "/images/vat-lieu/kim-loai/Inox-xuoc-bac.jpg" },
  { id: 'trang-guong', name: "Vân Tráng Gương", desc: "Bề mặt siêu bóng, mở rộng không gian và tạo điểm nhấn đẳng cấp.", image: "/images/vat-lieu/trang-guong.webp" },
];
---

<BaseLayout 
  title="Tổng Kho Film Dán Nội Thất - Đầy Đủ Các Loại Vân Cao Cấp" 
  description="Khám phá bộ sưu tập film dán nội thất đa dạng: vân gỗ, vân đá, bê tông, kim loại. Vật liệu chính hãng, độ bền trên 10 năm, thi công tại TP.HCM & Bình Dương."
>
  
  <section class="py-20 px-6 bg-base-50">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-light mb-6 italic">Bộ sưu tập <span class="font-medium">Vật Liệu</span></h1>
      <p class="text-base-500 max-w-2xl mx-auto text-lg">
        Chúng tôi cung cấp hơn 1000+ mẫu film dán kiến trúc với bề mặt mô phỏng chân thực, đáp ứng mọi phong cách thiết kế từ cổ điển đến công nghiệp.
      </p>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-16">
        {materials.map((item) => (
          <div class="group cursor-pointer">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden mb-6 bg-base-100 shadow-sm group-hover:shadow-2xl transition-all duration-500">
              <img 
                src={item.image} 
                alt={`Film dán nội thất ${item.name}`} 
                class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                loading="lazy"
              />
            </div>
            
            <h2 class="text-xl font-bold text-base-900 mb-3 group-hover:text-primary-500 transition">
              {item.name}
            </h2>
            <p class="text-sm text-base-500 leading-relaxed mb-4 line-clamp-3">
              {item.desc}
            </p>
            
            <a href={`/vat-lieu/${item.id}`} class="text-[10px] font-bold tracking-[0.2em] uppercase text-primary-500 border-b border-primary-500 pb-1 inline-block hover:bg-primary-500 hover:text-white hover:px-2 transition-all">
              Xem chi tiết
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-900 text-white rounded-[3rem] mx-4 md:mx-10 mb-24">
    <div class="max-w-4xl mx-auto">
      <h3 class="text-3xl font-light italic mb-8 text-center text-white/90">Tại sao nên chọn Film dán thay vì vật liệu truyền thống?</h3>
      <div class="grid md:grid-cols-2 gap-12 text-sm text-white/60">
        <div class="space-y-4">
          <p class="text-white font-medium">1. Khả năng kháng khuẩn & chống mốc</p>
          <p>Film nội thất cao cấp có lớp phủ nano giúp ngăn chặn vi khuẩn và nấm mốc, cực kỳ an toàn cho tủ bếp và môi trường có độ ẩm cao.</p>
        </div>
        <div class="space-y-4">
          <p class="text-white font-medium">2. Thi công không tiếng ồn, không mùi</p>
          <p>Khác với việc sơn hay ốp đá thật, dán film không gây bụi bặm, không mùi hóa chất, có thể sử dụng ngay sau khi thi công xong.</p>
        </div>
        <div class="space-y-4">
          <p class="text-white font-medium">3. Chịu nhiệt & Chống trầy xước</p>
          <p>Bề mặt film chịu được nhiệt độ cao (lên đến 80°C) và các va đập thông thường, bảo vệ cốt gỗ bên trong luôn như mới.</p>
        </div>
        <div class="space-y-4">
          <p class="text-white font-medium">4. Dễ dàng thay đổi</p>
          <p>Khi muốn đổi phong cách, bạn chỉ cần bóc lớp film cũ mà không làm hư hại bề mặt gốc, giúp làm mới không gian liên tục với chi phí thấp.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-light mb-8">Bạn chưa tìm thấy mẫu ưng ý?</h2>
      <p class="text-base-500 mb-10 italic">
        Chúng tôi có catalog với hơn 1000 mẫu vân thực tế tại văn phòng. Hãy để kỹ thuật viên mang mẫu đến tận nhà tư vấn cho bạn.
      </p>
      <a href="https://zalo.me/0866077040" class="inline-block bg-primary-500 text-white px-12 py-5 rounded-full font-bold shadow-xl hover:bg-primary-600 transition-all scale-100 hover:scale-105">
        Gửi mẫu catalog qua Zalo
      </a>
    </div>
  </section>

</BaseLayout>
