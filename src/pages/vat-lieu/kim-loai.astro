---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dữ liệu các mã màu vân kim loại (Metal)
const metalProducts = [
  { 
    brand: 'Toda', 
    name: "Inox Xước Bạc - MT902", 
    desc: "Bề mặt xước ngang tinh tế, phù hợp cho cabin thang máy và thiết bị bếp.", 
    image: "/images/vat-lieu/metal-silver.webp" 
  },
  { 
    brand: 'Infeel', 
    name: "Đồng Xước Rose Gold - MT45", 
    desc: "Tông màu sang trọng, đẳng cấp dành cho các mảng nhấn showroom, khách sạn.", 
    image: "/images/vat-lieu/kim-loai/CSM003.jpg" 
  },
  { 
    brand: 'Coance', 
    name: "Thép Titan Đen - CT11", 
    desc: "Màu đen sâu có ánh kim, tạo vẻ ngoài hiện đại và mạnh mẽ cho không gian Industrial.", 
    image: "/images/vat-lieu/metal-black.webp" 
  },
  { 
    brand: 'Infeel', 
    name: "Nhôm Xước Champagne - MT22", 
    desc: "Sắc vàng nhẹ thanh lịch, thay thế hoàn hảo cho các tấm ốp nhôm đắt tiền.", 
    image: "/images/vat-lieu/metal-gold.webp" 
  }
];

const features = [
  { title: "Chống vân tay", detail: "Lớp phủ đặc biệt giúp bề mặt kim loại luôn sạch sẽ." },
  { title: "Chịu nhiệt tốt", detail: "Phù hợp dán các thiết bị tỏa nhiệt như tủ lạnh, lò nướng." },
  { title: "Trọng lượng nhẹ", detail: "Tạo vẻ ngoài kim loại thật mà không gây nặng tải cho công trình." }
];
---

<BaseLayout 
  title="Film Dán Nội Thất Vân Kim Loại - Giải Pháp Cho Thang Máy & Thiết Bị"
  description="Bộ sưu tập film dán vân kim loại: Inox xước, titan, đồng, nhôm xước chính hãng Toda, Infeel. Chuyên dụng dán cabin thang máy, tủ lạnh tại TP.HCM & Bình Dương."
>

  <section class="py-20 px-6 bg-base-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/blog/cong-trinh-dan-film-noi-that-van-kim-loai.jpg" class="w-full h-full object-cover" alt="Background vân kim loại" />
    </div>
    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-light mb-6 italic">Vân <span class="font-medium">Kim Loại</span></h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg leading-relaxed">
        Mang lại vẻ đẹp công nghiệp, hiện đại và sang trọng của kim loại thật lên mọi bề mặt nội thất với chi phí tối ưu nhất.
      </p>
    </div>
  </section>

  <section class="py-16 px-6 bg-base-50">
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8">
      {features.map(f => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-base-100">
          <h3 class="font-bold text-primary-500 mb-2 uppercase text-xs tracking-widest">{f.title}</h3>
          <p class="text-sm text-base-500">{f.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {metalProducts.map(item => (
          <div class="group">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden mb-6 bg-base-100 shadow-sm group-hover:shadow-2xl transition duration-500">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
            </div>
            <p class="text-[10px] font-bold text-primary-500 uppercase mb-2">{item.brand}</p>
            <h2 class="text-lg font-bold text-base-900 mb-2 group-hover:text-primary-500 transition">{item.name}</h2>
            <p class="text-xs text-base-500 leading-relaxed line-clamp-2">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-50 rounded-[3rem] mx-4 mb-24">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-light italic mb-12">Ứng dụng <span class="font-medium text-base-900">Thực tế</span></h2>
      <div class="grid md:grid-cols-2 gap-12 text-left text-sm leading-relaxed text-base-600">
        <div class="bg-white p-6 rounded-xl">
          <h4 class="font-bold text-base-900 mb-2">Dán cabin thang máy</h4>
          <p>Thay vì thay mới tấm inox đắt tiền, dán film kim loại giúp che phủ các vết trầy xước cũ, làm mới thang máy chỉ trong 4-6 tiếng thi công.</p>
        </div>
        <div class="bg-white p-6 rounded-xl">
          <h4 class="font-bold text-base-900 mb-2">Cải tạo đồ gia dụng</h4>
          <p>Làm mới tủ lạnh, máy giặt cũ bằng vân nhôm xước hoặc titan, giúp thiết bị cũ trở nên hiện đại và đồng bộ với không gian bếp mới.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-light mb-8 italic">Bạn cần xem mẫu vân kim loại trực tiếp?</h2>
      <a href="https://zalo.me/0866077040" class="inline-block bg-primary-500 text-white px-12 py-5 rounded-full font-bold shadow-xl hover:bg-primary-600 transition-all">
        Gửi bảng mã màu qua Zalo
      </a>
    </div>
  </section>

</BaseLayout>
